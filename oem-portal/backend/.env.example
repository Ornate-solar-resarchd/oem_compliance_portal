# ── Database ──────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://neondb_owner:YOUR_PASSWORD@ep-muddy-fog-a19yvtsi.ap-southeast-1.aws.neon.tech/neondb?ssl=require
DATABASE_URL_SYNC=postgresql://neondb_owner:YOUR_PASSWORD@ep-muddy-fog-a19yvtsi.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth (Keycloak) ───────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=unityess
KEYCLOAK_CLIENT_ID=tcp-backend
KEYCLOAK_CLIENT_SECRET=YOUR_CLIENT_SECRET
JWT_ALGORITHM=RS256

# ── MinIO ─────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_DATASHEETS=datasheets
MINIO_BUCKET_DOCUMENTS=documents
MINIO_SECURE=false

# ── Anthropic (AI extraction) ──────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
CLAUDE_MODEL=claude-sonnet-4-6

# ── App ───────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_USE_RANDOM_32_BYTES
